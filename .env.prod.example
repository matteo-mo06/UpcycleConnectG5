# Template pour le .env racine en production
# Copier en .env et remplir les valeurs

# Base de données
DB_NAME=upcycle
DB_PASSWORD=MOT_DE_PASSE_ROOT_MYSQL

# Frontend — variables baked dans le build Vite au moment du docker build
VITE_API_URL=http://IP_OU_DOMAINE_SERVEUR
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE_STRIPE_PUBLIQUE
VITE_ONESIGNAL_APP_ID=VOTRE_APP_ID_ONESIGNAL

# Chemins NAS montés sur le serveur hôte (laisser vide pour volumes Docker locaux)
UPLOADS_HOST_PATH=/chemin/vers/nas/uploads
INVOICES_HOST_PATH=/chemin/vers/nas/invoices
