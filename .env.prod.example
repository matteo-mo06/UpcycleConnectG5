# template d'exemple pour .env en production

# Variables frontend (baked dans le build Vite au moment du docker build)
VITE_API_URL=http://IP_OU_DOMAINE_SERVEUR
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE_STRIPE_PUBLIQUE

# Chemin du dossier NAS monte sur le serveur web (stockage des images)
UPLOADS_HOST_PATH=/chemin/vers/dossier/nas/monte/sur/serveur
