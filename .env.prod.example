# Template pour le .env racine en production
# Copier en .env et remplir les valeurs
# Ce fichier est lu par docker-compose.prod.yml

# Frontend — variables intégrées au build Vite lors du docker build
# VITE_API_URL doit pointer vers le domaine/IP public du serveur (port 80, pas 8084)
VITE_API_URL=http://IP_OU_DOMAINE_SERVEUR
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE_STRIPE_PUBLIQUE
VITE_ONESIGNAL_APP_ID=VOTRE_APP_ID_ONESIGNAL

# Chemins des dossiers NAS montés sur le serveur hôte (via NFS ou CIFS)
# Ces chemins doivent exister sur le serveur avant de lancer docker compose
UPLOADS_HOST_PATH=/mnt/nas/uploads
INVOICES_HOST_PATH=/mnt/nas/invoices
