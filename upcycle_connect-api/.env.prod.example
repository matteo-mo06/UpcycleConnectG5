# Template pour upcycle_connect-api/.env en production
# Copier en .env et remplir les valeurs
# Ce fichier est lu directement par le conteneur backend (env_file dans docker-compose.prod.yml)

PORT=8084
BASE_URL=http://IP_OU_DOMAINE_SERVEUR
FRONTEND_URL=http://IP_OU_DOMAINE_SERVEUR

# URL publique du serveur — utilisée pour les webhooks Stripe
PLATFORM_URL=http://IP_OU_DOMAINE_SERVEUR

# Base de données sur le NAS (MySQL/MariaDB externe, pas un conteneur Docker)
DB_HOST=IP_DU_NAS
DB_PORT=3306
DB_USER=UTILISATEUR_MYSQL
DB_PASSWORD=MOT_DE_PASSE_MYSQL
DB_NAME=upcycle

JWT_SECRET=CHANGEZ_CETTE_CLE_AVEC_UNE_VALEUR_LONGUE_ET_ALEATOIRE

# Doit correspondre à VITE_API_URL dans le .env racine
CORS_ORIGIN=http://IP_OU_DOMAINE_SERVEUR

ADMIN_EMAIL=admin@votre-domaine.com
ADMIN_PASSWORD=MotDePasseAdminFort!

STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_STRIPE_PRODUCTION
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_WEBHOOK_SECRET_PRODUCTION

UPLOADS_DIR=/app/uploads
INVOICES_DIR=/app/invoices

ONESIGNAL_APP_ID=VOTRE_APP_ID_ONESIGNAL
ONESIGNAL_API_KEY=VOTRE_API_KEY_ONESIGNAL
